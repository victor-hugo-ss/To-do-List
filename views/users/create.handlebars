<!-- views/users/create.handlebars -->
<div class="page-header">
  <h1 class="page-title">Novo Usuário</h1>
  <a href="/users" class="btn btn-ghost">← Voltar</a>
</div>

<form action="/users/create" method="POST" id="createUserForm">

  <!-- DADOS PESSOAIS -->
  <section class="card">
    <h2 class="section-title">Dados Pessoais</h2>
    <div class="form-grid">
      <div class="field field--full">
        <label for="name">Nome completo</label>
        <input
          type="text"
          id="name"
          name="name"
          placeholder="Ex: João Silva"
          required
        />
      </div>
      <div class="field">
        <label for="occupation">Ocupação</label>
        <input
          type="text"
          id="occupation"
          name="occupation"
          placeholder="Ex: Desenvolvedor"
          required
        />
      </div>
      <div class="field">
        <label for="email">E-mail</label>
        <input
          type="email"
          id="email"
          name="email"
          placeholder="joao@email.com"
          required
        />
      </div>
    </div>
  </section>

  <!-- ENDEREÇOS -->
  <div id="addresses-container">
    <section class="card" data-address="0">
      <div class="section-header">
        <h2 class="section-title">Endereço 1</h2>
      </div>
      <div class="form-grid">
        <div class="field">
          <label>CEP</label>
          <input
            type="text"
            name="addresses[0][zipcode]"
            placeholder="00000-000"
            maxlength="9"
            class="zipcode-input"
          />
        </div>
        <div class="field">
          <label>Rua</label>
          <input
            type="text"
            name="addresses[0][street]"
            placeholder="Nome da rua"
            class="street-input"
          />
        </div>
        <div class="field field--small">
          <label>Número</label>
          <input type="text" name="addresses[0][number]" placeholder="123" />
        </div>
        <div class="field">
          <label>Cidade</label>
          <input
            type="text"
            name="addresses[0][city]"
            placeholder="Sua cidade"
            class="city-input"
          />
        </div>
        <div class="field field--small">
          <label>Estado</label>
          <select name="addresses[0][state]" class="state-input">
            <option value="">UF</option>
            <option>AC</option><option>AL</option><option>AP</option><option
            >AM</option>
            <option>BA</option><option>CE</option><option>DF</option><option
            >ES</option>
            <option>GO</option><option>MA</option><option>MT</option><option
            >MS</option>
            <option>MG</option><option>PA</option><option>PB</option><option
            >PR</option>
            <option>PE</option><option>PI</option><option>RJ</option><option
            >RN</option>
            <option>RS</option><option>RO</option><option>RR</option><option
            >SC</option>
            <option>SP</option><option>SE</option><option>TO</option>
          </select>
        </div>
      </div>
    </section>
  </div>

  <button type="button" id="add-address" class="btn btn-outline">+ Adicionar
    endereço</button>

  <div class="form-actions">
    <a href="/users" class="btn btn-ghost">Cancelar</a>
    <button type="submit" class="btn btn-primary">Cadastrar usuário</button>
  </div>

</form>